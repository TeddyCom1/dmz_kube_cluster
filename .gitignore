# Local .terraform directory
.terraform/

# Terraform lock file (keep if you want reproducible provider versions)
# .terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files
*.tfplan

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log
crash.log
crash.*.log

.env
